# Fresh Greens — Local Development Environment Variables
#
#  HOW THIS WORKS
#  ──────────────
#  DotenvEnvironmentPostProcessor loads this file at startup and injects
#  every variable into Spring's property sources — BELOW system environment
#  variables, so GitHub Actions secrets / OS exports always take priority.
#
#  DO NOT COMMIT THIS FILE — it is listed in .gitignore.
#  Copy app/.env.example → app/.env and fill in your local values.
# ─────────────────────────────────────────────────────────────────────────────

# ── MySQL ─────────────────────────────────────────────────────────────────────
DB_URL=jdbc:mysql://localhost:3306/fresh_greens_db?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=

# ── Razorpay (Test Mode keys from https://dashboard.razorpay.com/app/keys) ────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=YOUR_RAZORPAY_WEBHOOK_SECRET
